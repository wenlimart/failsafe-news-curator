# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Environment variables / secrets
.env

# Generated article data (keep directory, ignore contents)
articles_raw/*
!articles_raw/.gitkeep

articles_normalized/*
!articles_normalized/.gitkeep

articles_ready/*
!articles_ready/.gitkeep

scored_articles/*
!scored_articles/.gitkeep

# Publish output
# docs/index.md と日付別ページはコミット対象（GitHub Pages で公開）
# docs/internal/ はコミット対象外（内部確認用）
docs/internal/

# Logs and review records (keep directory, ignore contents)
logs/*.log
logs/*.csv
!logs/.gitkeep

# OS / editor
.DS_Store
.vscode/
.idea/
